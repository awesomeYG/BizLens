# OpenAI API Key（可选，用于 AI 对话真实分析）
OPENAI_API_KEY=sk-xxx

# Go 后端服务地址
NEXT_PUBLIC_API_URL=http://localhost:3001

# 数据库配置（Go 后端使用）
# 使用 PostgreSQL（生产环境）
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ai_bi
DB_SSLMODE=disable

# 使用 SQLite（开发/测试，设为 true 启用）
USE_SQLITE=false

# 服务端口
SERVER_PORT=3001
