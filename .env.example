# OpenAI 兼容 API Key（可选，用于 AI 对话真实分析，也可填写 MiniMax Key）
OPENAI_API_KEY=sk-xxx

# 如使用 MiniMax，可配置为其 OpenAI 兼容入口
# OPENAI_BASE_URL=https://api.minimax.io/v1

# Go 后端服务地址
NEXT_PUBLIC_API_URL=http://localhost:3001

# 数据库配置（Go 后端使用）
# 使用 PostgreSQL（生产环境）
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ai_bi
DB_SSLMODE=disable

# 使用 SQLite（开发/测试，设为 true 启用）
USE_SQLITE=false

# 服务端口
SERVER_PORT=3001

# 环境配置
ENV=development

# JWT 认证配置（生产环境必须修改为强密钥）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-at-least-32-chars

# ==========================================
# 授权码配置（必填，格式 XXXX-XXXX-XXXX-XXXX）
# ==========================================
# 测试/开发环境使用以下固定授权码（不可用于生产）：
LICENSE_KEY=TEST-BIZL-0000-0001
# LICENSE_KEY=BIZL-8K3M-A7PW-2N9Q   # 生产授权码示例

# 最大用户数上限（可选，不填则不限制）
# LICENSE_SEATS=50

# 授权到期日期（可选，格式 YYYY-MM-DD，不填则永不过期）
# LICENSE_EXPIRES=2027-12-31
