# 服务器配置
SERVER_PORT=3001

# 数据库配置
USE_SQLITE=true
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ai_bi
DB_SSLMODE=disable

# 认证配置
# 生产环境务必修改此密钥
JWT_SECRET=change-this-secret-in-production
# 环境：development / production
ENV=development
# 前端应用地址（用于生成密码重置邮件链接）
APP_BASE_URL=http://localhost:3000
# Access Token 过期时间（分钟），默认 30 分钟
ACCESS_TOKEN_EXPIRE=30
# Refresh Token 过期时间（天），默认 7 天
REFRESH_TOKEN_EXPIRE=7

# SMTP 邮件配置（启用邮件找回密码时填写）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=no-reply@example.com
# SMTP_PASSWORD=change-me
# SMTP_FROM=BizLens <no-reply@example.com>

# 最大登录失败尝试次数
MAX_LOGIN_ATTEMPTS=5
# 账户锁定时间（分钟）
ACCOUNT_LOCK_DURATION=30

# ==========================================
# 授权码配置（必填，格式 XXXX-XXXX-XXXX-XXXX）
# ==========================================
# 测试/开发环境使用以下固定授权码（不可用于生产）：
LICENSE_KEY=TEST-BIZL-0000-0001
# LICENSE_KEY=BIZL-8K3M-A7PW-2N9Q   # 生产授权码示例

# 最大用户数上限（可选，不填则不限制）
# LICENSE_SEATS=50

# 授权到期日期（可选，格式 YYYY-MM-DD，不填则永不过期）
# LICENSE_EXPIRES=2027-12-31
