# 服务器配置
SERVER_PORT=3001

# 数据库配置
USE_SQLITE=true
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ai_bi
DB_SSLMODE=disable

# 认证配置
# 生产环境务必修改此密钥
JWT_SECRET=change-this-secret-in-production
# 环境：development / production
ENV=development
# Access Token 过期时间（分钟），默认 30 分钟
ACCESS_TOKEN_EXPIRE=30
# Refresh Token 过期时间（天），默认 7 天
REFRESH_TOKEN_EXPIRE=7

# 最大登录失败尝试次数
MAX_LOGIN_ATTEMPTS=5
# 账户锁定时间（分钟）
ACCOUNT_LOCK_DURATION=30
