# ============================================================
# 开发/测试环境本地配置
# ============================================================
# 此文件仅用于本地开发，不会被提交到 Git
# 复制此文件为 .env.local 后修改对应值即可使用
# ============================================================

# 授权码（必填）
# 测试/开发专用授权码（Phase 0 实施后生效）
LICENSE_KEY=TEST-BIZL-0000-0001

# 默认开发模式使用 SQLite；如需 PostgreSQL，请取消注释以下配置。
# 后端会自动读取项目根目录的 .env.local。
# USE_SQLITE=false
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_bi?sslmode=disable
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=ai_bi
# DB_SSLMODE=disable

# 可选：最大用户数上限（不填则不限制）
# LICENSE_SEATS=50

# 可选：授权到期日期（格式 YYYY-MM-DD）
# LICENSE_EXPIRES=2027-12-31
